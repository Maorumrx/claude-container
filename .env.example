# Copy ไฟล์นี้เป็น .env.local แล้วกรอกข้อมูลของคุณ
# ไฟล์ .env.local จะถูก gitignore ไม่ถูก commit ขึ้น repo

GIT_CONFIG_NAME=Your Name
GIT_CONFIG_EMAIL=your@email.com

# Proxy (ไม่บังคับ — ถ้าไม่ใช้ปล่อยว่างหรือลบบรรทัดนี้ทิ้งได้)
# HTTP_PROXY=http://proxy.example.com:3128
# HTTPS_PROXY=http://proxy.example.com:3128
# NO_PROXY=localhost,127.0.0.1
