{
  "name": "Claude Dev Container",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".",
    "args": {
      "NODE_VERSION": "24",
      "INSTALL_CLAUDE_CLI": "true",
      "TZ": "Asia/Bangkok"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "anthropic.claude-code",
        "DEVSENSE.composer-php-vscode",
        "ms-azuretools.vscode-containers",
        "dbaeumer.vscode-eslint",
        "mhutchie.git-graph",
        "donjayamanne.githistory",
        "GitHub.copilot-chat",
        "GitHub.vscode-pull-request-github",
        "eamodio.gitlens",
        "DEVSENSE.intelli-php-vscode",
        "ZainChen.json",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "onecentlin.laravel5-snippets",
        "DEVSENSE.phptools-vscode",
        "xdebug.php-debug",
        "DEVSENSE.profiler-php-vscode",
        "esbenp.prettier-vscode",
        "redhat.vscode-yaml",
        "formulahendry.auto-rename-tag",
        "pkief.material-icon-theme"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": { "path": "bash", "icon": "terminal-bash" },
          "zsh": { "path": "zsh" }
        }
      }
    }
  },
  "remoteUser": "node",
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    // WSL / Mac / Linux → ใช้บรรทัดนี้
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind,consistency=delegated"
    // Windows (PowerShell/CMD) → เปลี่ยนเป็น: "source=${localEnv:USERPROFILE}/.claude,target=/home/node/.claude,type=bind,consistency=delegated"
  ],
  "remoteEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "POWERLEVEL9K_DISABLE_GITSTATUS": "true"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=delegated",
  "workspaceFolder": "/workspace",
  "postCreateCommand": "bash /workspace/.devcontainer/scripts/setup.sh",
  "forwardPorts": [80, 443, 3306, 6379, 6001],
  "portsAttributes": {
    "80":   { "label": "Nginx HTTP",        "onAutoForward": "notify"  },
    "443":  { "label": "Nginx HTTPS",       "onAutoForward": "silent"  },
    "3306": { "label": "MySQL",             "onAutoForward": "silent"  },
    "6379": { "label": "Redis",             "onAutoForward": "silent"  },
    "6001": { "label": "Soketi WebSocket",  "onAutoForward": "silent"  }
  }
}
